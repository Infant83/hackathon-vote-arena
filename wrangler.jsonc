{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "hack",
  "main": "worker/index.ts",
  "compatibility_date": "2026-05-09",
  "workers_dev": true,
  "preview_urls": false,
  "limits": {
    "cpu_ms": 300000
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/events*"]
  },
  "vars": {
    "ARENA_ROOM_NAME": "default"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "ARENA_ROOM",
        "class_name": "ArenaRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ArenaRoom"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
